{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smart-workflow.example.com/task-schema.json",
  "title": "SMART Task Definition",
  "description": "Schema for defining tasks using the SMART framework for multi-agent workflows",
  "type": "object",
  "required": ["task_id", "specific", "measurable", "achievable", "relevant", "time_bound", "deliverables", "acceptance_criteria"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Unique identifier for the task",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "examples": ["auth-001", "api-endpoint-002"]
    },
    "specific": {
      "type": "string",
      "description": "Clear description of what needs to be done (S - Specific)",
      "minLength": 10,
      "examples": ["Implement JWT-based user authentication with login, logout, and token refresh"]
    },
    "measurable": {
      "type": "string",
      "description": "How to verify completion (M - Measurable)",
      "minLength": 10,
      "examples": ["Auth middleware handles 100% of protected routes, all tests pass with >90% coverage"]
    },
    "achievable": {
      "type": "string",
      "description": "Why this task is possible given current context (A - Achievable)",
      "minLength": 10,
      "examples": ["Using existing Express framework, JWT library already in dependencies"]
    },
    "relevant": {
      "type": "string",
      "description": "How this contributes to the larger goal (R - Relevant)",
      "minLength": 10,
      "examples": ["Required for all user-facing features, blocks profile implementation"]
    },
    "time_bound": {
      "type": "string",
      "description": "Expected completion time or deadline (T - Time-bound)",
      "minLength": 5,
      "examples": ["Complete within 2 hours", "Before Friday EOD", "ASAP - blocks other work"]
    },
    "deliverables": {
      "type": "array",
      "description": "List of concrete deliverables",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the deliverable",
            "examples": ["auth-middleware.ts"]
          },
          "type": {
            "type": "string",
            "enum": ["file", "function", "module", "test", "documentation", "configuration"],
            "description": "Type of deliverable"
          },
          "path": {
            "type": "string",
            "description": "File path if applicable",
            "examples": ["src/middleware/auth.ts"]
          },
          "description": {
            "type": "string",
            "description": "Brief description of the deliverable"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "Specific conditions that must be met for acceptance",
      "items": {
        "type": "object",
        "required": ["criterion", "verifiable"],
        "properties": {
          "criterion": {
            "type": "string",
            "description": "The acceptance criterion"
          },
          "verifiable": {
            "type": "boolean",
            "description": "Whether this criterion can be objectively verified"
          },
          "method": {
            "type": "string",
            "description": "How to verify this criterion",
            "examples": ["run tests", "check file exists", "manual verification"]
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "resources": {
      "type": "array",
      "description": "Required tools, files, or dependencies",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the resource"
          },
          "type": {
            "type": "string",
            "enum": ["file", "library", "tool", "service", "permission"],
            "description": "Type of resource"
          },
          "path": {
            "type": "string",
            "description": "Path or URL if applicable"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this resource is required or optional",
            "default": true
          }
        },
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "description": "Potential blockers or challenges",
      "items": {
        "type": "object",
        "required": ["risk", "impact", "mitigation"],
        "properties": {
          "risk": {
            "type": "string",
            "description": "Description of the risk"
          },
          "impact": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Impact level if risk occurs"
          },
          "mitigation": {
            "type": "string",
            "description": "How to mitigate or handle this risk"
          }
        },
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "description": "Other tasks this depends on",
      "items": {
        "type": "object",
        "required": ["task_id", "type"],
        "properties": {
          "task_id": {
            "type": "string",
            "description": "ID of the dependent task"
          },
          "type": {
            "type": "string",
            "enum": ["blocks", "blocked-by", "related-to"],
            "description": "Type of dependency"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Task priority level"
        },
        "complexity": {
          "type": "string",
          "enum": ["simple", "moderate", "complex", "expert"],
          "description": "Task complexity level"
        },
        "estimated_hours": {
          "type": "number",
          "description": "Estimated hours to complete",
          "minimum": 0
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}