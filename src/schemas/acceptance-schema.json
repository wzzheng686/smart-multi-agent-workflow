{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smart-workflow.example.com/acceptance-schema.json",
  "title": "SMART Acceptance Report",
  "description": "Schema for main agent acceptance verification reports using SMART criteria",
  "type": "object",
  "required": ["task_id", "acceptance_id", "acceptance_timestamp", "decision", "verifier", "original_task", "verification_results", "acceptance_criteria", "overall_score", "decision_rationale"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "ID of the task being verified",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "acceptance_id": {
      "type": "string",
      "description": "Unique identifier for this acceptance record",
      "pattern": "^acc-[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "acceptance_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when acceptance was performed"
    },
    "decision": {
      "type": "string",
      "enum": ["accepted", "rejected", "conditional"],
      "description": "The acceptance decision"
    },
    "verifier": {
      "type": "string",
      "description": "Identifier of the agent performing verification"
    },
    "original_task": {
      "type": "object",
      "description": "Reference to the original task definition",
      "required": ["task_id"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "ID of the original task"
        },
        "smart_definition": {
          "type": "object",
          "description": "The original SMART task definition",
          "properties": {
            "specific": { "type": "string" },
            "measurable": { "type": "string" },
            "achievable": { "type": "string" },
            "relevant": { "type": "string" },
            "time_bound": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "verification_results": {
      "type": "object",
      "description": "Verification results for each SMART dimension",
      "required": ["specific", "measurable", "achievable", "relevant", "time_bound"],
      "properties": {
        "specific": {
          "$ref": "#/definitions/verificationResult"
        },
        "measurable": {
          "$ref": "#/definitions/verificationResult"
        },
        "achievable": {
          "$ref": "#/definitions/verificationResult"
        },
        "relevant": {
          "$ref": "#/definitions/verificationResult"
        },
        "time_bound": {
          "$ref": "#/definitions/verificationResult"
        }
      },
      "additionalProperties": false
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "Verification of each acceptance criterion",
      "items": {
        "$ref": "#/definitions/criterionVerification"
      },
      "minItems": 1
    },
    "overall_score": {
      "type": "number",
      "description": "Overall SMART score (0-100)",
      "minimum": 0,
      "maximum": 100
    },
    "decision_rationale": {
      "type": "string",
      "description": "Explanation of why this decision was made",
      "minLength": 10
    },
    "conditions": {
      "type": "array",
      "description": "Conditions for conditional acceptance",
      "items": {
        "type": "object",
        "required": ["condition", "deadline"],
        "properties": {
          "condition": {
            "type": "string",
            "description": "The condition that must be met"
          },
          "deadline": {
            "type": "string",
            "description": "Deadline for meeting this condition"
          },
          "consequence": {
            "type": "string",
            "description": "What happens if condition is not met"
          }
        },
        "additionalProperties": false
      }
    },
    "feedback": {
      "type": "array",
      "description": "Feedback for the subagent",
      "items": {
        "$ref": "#/definitions/feedbackItem"
      }
    },
    "verification_evidence": {
      "type": "array",
      "description": "Evidence collected during verification",
      "items": {
        "$ref": "#/definitions/evidence"
      }
    },
    "next_steps": {
      "type": "array",
      "description": "Actions to take after acceptance",
      "items": {
        "type": "string"
      }
    },
    "self_check_comparison": {
      "type": "object",
      "description": "Comparison with subagent's self-check",
      "properties": {
        "self_check_score": {
          "type": "number",
          "description": "Score from subagent's self-check"
        },
        "acceptance_score": {
          "type": "number",
          "description": "Score from this acceptance check"
        },
        "variance": {
          "type": "number",
          "description": "Difference between scores"
        },
        "assessment": {
          "type": "string",
          "enum": ["accurate", "overconfident", "underconfident"],
          "description": "How accurate was the self-check"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "verificationResult": {
      "type": "object",
      "required": ["passed", "evidence"],
      "properties": {
        "passed": {
          "type": "boolean",
          "description": "Whether this dimension passed verification"
        },
        "evidence": {
          "type": "string",
          "description": "Evidence supporting this verification"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Any issues found during verification"
        }
      },
      "additionalProperties": false
    },
    "criterionVerification": {
      "type": "object",
      "required": ["criterion", "met", "evidence"],
      "properties": {
        "criterion": {
          "type": "string",
          "description": "The acceptance criterion"
        },
        "met": {
          "type": "boolean",
          "description": "Whether the criterion is met"
        },
        "evidence": {
          "type": "string",
          "description": "Proof of verification"
        }
      },
      "additionalProperties": false
    },
    "feedbackItem": {
      "type": "object",
      "required": ["type", "message"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["praise", "improvement", "critical"],
          "description": "Type of feedback"
        },
        "message": {
          "type": "string",
          "description": "The feedback message"
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file", "test_output", "metric", "screenshot", "log", "command_output"],
          "description": "Type of evidence"
        },
        "description": {
          "type": "string",
          "description": "Description of the evidence"
        },
        "path": {
          "type": "string",
          "description": "File path or reference"
        },
        "content": {
          "type": "string",
          "description": "Content or summary of the evidence"
        }
      },
      "additionalProperties": false
    }
  }
}