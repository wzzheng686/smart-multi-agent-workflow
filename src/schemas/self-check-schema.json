{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smart-workflow.example.com/self-check-schema.json",
  "title": "SMART Self-Check Report",
  "description": "Schema for subagent self-assessment reports using SMART criteria",
  "type": "object",
  "required": ["task_id", "subagent_id", "check_timestamp", "completion_percentage", "smart_scores", "overall_score", "deliverables_completed", "acceptance_criteria_met", "confidence_level"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "ID of the task being checked",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "subagent_id": {
      "type": "string",
      "description": "Identifier of the subagent performing the check"
    },
    "check_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the check was performed"
    },
    "completion_percentage": {
      "type": "number",
      "description": "Overall completion percentage (0-100)",
      "minimum": 0,
      "maximum": 100
    },
    "smart_scores": {
      "type": "object",
      "description": "Scores for each SMART dimension",
      "required": ["specific", "measurable", "achievable", "relevant", "time_bound"],
      "properties": {
        "specific": {
          "$ref": "#/definitions/smartScore"
        },
        "measurable": {
          "$ref": "#/definitions/smartScore"
        },
        "achievable": {
          "$ref": "#/definitions/smartScore"
        },
        "relevant": {
          "$ref": "#/definitions/smartScore"
        },
        "time_bound": {
          "$ref": "#/definitions/smartScore"
        }
      },
      "additionalProperties": false
    },
    "overall_score": {
      "type": "number",
      "description": "Overall SMART score (0-100)",
      "minimum": 0,
      "maximum": 100
    },
    "deliverables_completed": {
      "type": "array",
      "description": "Status of each deliverable",
      "items": {
        "$ref": "#/definitions/deliverableStatus"
      },
      "minItems": 1
    },
    "acceptance_criteria_met": {
      "type": "array",
      "description": "Status of each acceptance criterion",
      "items": {
        "$ref": "#/definitions/criterionStatus"
      },
      "minItems": 1
    },
    "issues_found": {
      "type": "array",
      "description": "Any issues discovered during self-check",
      "items": {
        "$ref": "#/definitions/issue"
      }
    },
    "test_results": {
      "type": "object",
      "description": "Results of verification commands",
      "properties": {
        "tests_passed": {
          "type": "boolean",
          "description": "Whether all tests passed"
        },
        "test_output": {
          "type": "string",
          "description": "Raw test output"
        },
        "coverage": {
          "type": "number",
          "description": "Test coverage percentage",
          "minimum": 0,
          "maximum": 100
        },
        "lint_passed": {
          "type": "boolean",
          "description": "Whether lint checks passed"
        },
        "type_check_passed": {
          "type": "boolean",
          "description": "Whether type checks passed"
        },
        "build_passed": {
          "type": "boolean",
          "description": "Whether build succeeded"
        }
      },
      "additionalProperties": false
    },
    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Subagent's confidence in the work quality"
    },
    "notes": {
      "type": "string",
      "description": "Additional context or concerns"
    },
    "evidence": {
      "type": "array",
      "description": "Supporting evidence for the self-check",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["file", "test_output", "metric", "screenshot", "log"],
            "description": "Type of evidence"
          },
          "description": {
            "type": "string",
            "description": "Description of the evidence"
          },
          "path": {
            "type": "string",
            "description": "File path or reference"
          },
          "content": {
            "type": "string",
            "description": "Content or summary of the evidence"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "smartScore": {
      "type": "object",
      "required": ["score", "evidence"],
      "properties": {
        "score": {
          "type": "number",
          "description": "Score for this SMART dimension (0-100)",
          "minimum": 0,
          "maximum": 100
        },
        "evidence": {
          "type": "string",
          "description": "Evidence supporting this score"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Any issues with this dimension"
        }
      },
      "additionalProperties": false
    },
    "deliverableStatus": {
      "type": "object",
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the deliverable"
        },
        "path": {
          "type": "string",
          "description": "File path if applicable"
        },
        "status": {
          "type": "string",
          "enum": ["complete", "partial", "missing", "not_applicable"],
          "description": "Completion status"
        },
        "evidence": {
          "type": "string",
          "description": "Evidence of completion"
        }
      },
      "additionalProperties": false
    },
    "criterionStatus": {
      "type": "object",
      "required": ["criterion", "met"],
      "properties": {
        "criterion": {
          "type": "string",
          "description": "The acceptance criterion"
        },
        "met": {
          "type": "boolean",
          "description": "Whether the criterion is met"
        },
        "evidence": {
          "type": "string",
          "description": "Evidence of verification"
        }
      },
      "additionalProperties": false
    },
    "issue": {
      "type": "object",
      "required": ["severity", "description"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "major", "minor"],
          "description": "Severity of the issue"
        },
        "description": {
          "type": "string",
          "description": "Description of the issue"
        },
        "resolution": {
          "type": "string",
          "description": "How it was resolved or plan to resolve"
        }
      },
      "additionalProperties": false
    }
  }
}