{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://smart-workflow.example.com/meta-schema.json",
  "title": "SMART Workflow Archive Metadata",
  "description": "Schema for workflow archive metadata used in export/import operations",
  "type": "object",
  "required": ["name", "version", "description", "author", "license", "created_at", "updated_at", "platforms", "skills", "schemas"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the workflow archive",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "examples": ["smart-workflow"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version (e.g., 1.0.0)",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$$",
      "examples": ["1.0.0", "1.2.3-beta.1"]
    },
    "description": {
      "type": "string",
      "description": "Brief description of the workflow",
      "minLength": 10,
      "maxLength": 500
    },
    "author": {
      "type": "string",
      "description": "Author name or organization",
      "minLength": 2
    },
    "license": {
      "type": "string",
      "description": "License identifier (SPDX format)",
      "examples": ["MIT", "Apache-2.0", "GPL-3.0"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of last update"
    },
    "platforms": {
      "type": "array",
      "description": "Supported agent platforms",
      "items": {
        "type": "string",
        "enum": ["opencode", "claude-code", "codex", "hermes", "custom"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "skills": {
      "type": "array",
      "description": "List of included skills",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "schemas": {
      "type": "array",
      "description": "List of included JSON schemas",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "templates": {
      "type": "array",
      "description": "List of included prompt templates",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "adapters": {
      "type": "array",
      "description": "List of included platform adapters",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "description": "External dependencies",
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Dependency name"
          },
          "version": {
            "type": "string",
            "description": "Version constraint"
          },
          "optional": {
            "type": "boolean",
            "description": "Whether this dependency is optional",
            "default": false
          }
        },
        "additionalProperties": false
      }
    },
    "compatibility": {
      "type": "object",
      "description": "Compatibility information",
      "properties": {
        "min_version": {
          "type": "string",
          "description": "Minimum version of the workflow engine"
        },
        "max_version": {
          "type": "string",
          "description": "Maximum version of the workflow engine"
        },
        "tested_platforms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Platforms that have been tested"
        },
        "node_version": {
          "type": "string",
          "description": "Required Node.js version"
        }
      },
      "additionalProperties": false
    },
    "changelog": {
      "type": "array",
      "description": "Version history",
      "items": {
        "type": "object",
        "required": ["version", "date", "changes"],
        "properties": {
          "version": {
            "type": "string",
            "description": "Version number"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Release date"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of changes"
          }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for categorization",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "repository": {
      "type": "object",
      "description": "Repository information",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Repository URL"
        },
        "branch": {
          "type": "string",
          "description": "Default branch"
        },
        "commit": {
          "type": "string",
          "description": "Specific commit hash"
        }
      },
      "additionalProperties": false
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Project homepage URL"
    },
    "bugs": {
      "type": "object",
      "description": "Bug tracking information",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Bug tracker URL"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}